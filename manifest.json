{
    "manifest_version": 3,
    "name": "Fanchant.ly",
    "description": "Play a K-POP fanchant mode on Youtube music",
    "version": "1.0",
    "icons": {
        "16": "/icons/icon-16.png",
        "48": "/icons/icon-48.png",
        "128": "/icons/icon-128.png"
    },
    "action": {
        "default_icon": "/icons/icon-16.png",
        "default_title": "Fanchant.ly",
        "default_popup": "popup.html"
    },
    "host_permissions": [
        "*://music.youtube.com/*"
    ],
    "permissions": [
        "storage",
        "activeTab"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://music.youtube.com/*"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "/icons/*",
                "/data/*/*.json"
            ],
            "matches": [
                "*://music.youtube.com/*"
            ]
        }
    ]
}